<?xml version="1.0" encoding="utf-8"?>
<!--
  Certificate arrays for the Google Fonts downloadable-font provider
  (com.google.android.gms.fonts). These certificates authenticate the
  provider used at runtime; without correct values, Google Fonts will be
  unavailable and the app will fall back to system fonts (handled gracefully
  in Typography.kt).

  HOW TO GENERATE:
  Android Studio can generate the correct certificate arrays automatically:
    1. Open a layout XML file.
    2. Click "More fonts..." in the font attribute picker.
    3. Select any Google Font and choose "Add font to project".
    4. Android Studio will create/overwrite this file with the correct certificates.

  Alternatively, copy the canonical version from the Android sample repository:
    https://github.com/android/user-interface-samples/blob/main/DownloadableFonts/app/src/main/res/values/font_certs.xml

  The certificate items below are PLACEHOLDERS. Google Fonts will fail silently
  and Typography.kt will automatically fall back to FontFamily.SansSerif.
  Replace them with real certificates before shipping to production.
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>

    <!--
      Replace the item below with the real dev certificate data.
      Generated by Android Studio or sourced from the sample linked above.
    -->
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>REPLACE_WITH_REAL_DEV_CERTIFICATE</item>
    </string-array>

    <!--
      Replace the item below with the real prod certificate data.
      Generated by Android Studio or sourced from the sample linked above.
    -->
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>REPLACE_WITH_REAL_PROD_CERTIFICATE</item>
    </string-array>
</resources>
