<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground layer — white phone/call icon centered in the
  72 × 72 dp safe zone of the 108 × 108 dp adaptive icon canvas.

  Android VectorDrawable applies <group> transforms in Scale → Translate order
  (per VectorDrawable source: postScale then postTranslate on the matrix).
  For a 24 × 24 path scaled by 3 the output size is 72 × 72 dp.
  To center 72 dp inside 108 dp: translateX = translateY = (108 − 72) / 2 = 18.
  Resulting bounds: [18, 90] × [18, 90] — centered at (54, 54) ✓
  This places the icon entirely within the adaptive-icon safe zone [18, 90].

  Path data: Material Design "call" (filled) icon — 24 × 24 viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="18"
        android:translateY="18"
        android:scaleX="3"
        android:scaleY="3">
